        android:fillColor="#7EC4FF"
        android:pathData="M54,58 m-10,0 a10,10 0,1 0,20 0 a10,10 0,1 0,-20 0" />
    <path
        android:fillColor="#0A1624"
        android:fillAlpha="0.92"
        android:pathData="M54,58 m-5,0 a5,5 0,1 0,10 0 a5,5 0,1 0,-10 0" />
    <!-- Packet dots (hint the relay path) -->
    <path
        android:fillColor="#7EC4FF"
        android:fillAlpha="0.85"
        android:pathData="M38,50 m-3,0 a3,3 0,1 0,6 0 a3,3 0,1 0,-6 0" />
    <path
        android:fillColor="#7EC4FF"
        android:fillAlpha="0.85"
        android:pathData="M70,50 m-3,0 a3,3 0,1 0,6 0 a3,3 0,1 0,-6 0" />
</vector>
